                  {
                      "parameters":  {
                                         "jsCode":  "const query = $json.callback_query || {};\nconst data = $json.callback_data || query.data || \"\";\nconst chat_id = $json.chat_id || query.message?.chat?.id || \"\";\nconst callback_query_id = $json.callback_query_id || query.id || \"\";\nconst clicked_by = $json.clicked_by || query.from?.first_name || \"Unknown\";\nconst telegram_user_id = $json.telegram_user_id || query.from?.id || \"\";\n\nlet action = \"\";\nlet decision = \"\";\nlet order_id = \"\";\nlet document_id = \"\";\nlet conversation_id = \"\";\n\nif (data.startsWith(\"approve_\")) {\n  action = \"process_order_approval_reply\";\n  decision = \"approve\";\n  order_id = data.replace(\"approve_\", \"\").trim().toUpperCase();\n} else if (data.startsWith(\"reject_\")) {\n  action = \"process_order_approval_reply\";\n  decision = \"reject\";\n  order_id = data.replace(\"reject_\", \"\").trim().toUpperCase();\n} else if (data.startsWith(\"quote_send|\") || data.startsWith(\"quote_cancel|\")) {\n  const parts = data.split(\"|\");\n  action = \"route_document_send_callback\";\n  order_id = (parts[1] || \"\").trim().toUpperCase();\n  document_id = (parts[2] || \"\").trim();\n  conversation_id = (parts[3] || \"\").trim();\n}\n\nif (!action) {\n  action = \"invalid_callback\";\n}\n\nreturn [\n  {\n    json: {\n      action,\n      decision,\n      order_id,\n      document_id,\n      conversation_id,\n      callback_data: data,\n      chat_id: String(chat_id),\n      callback_query_id,\n      changed_by: clicked_by,\n      trigger_source: \"Telegram Button\",\n      clicked_by,\n      telegram_user_id: String(telegram_user_id),\n      decision_method: \"Button\"\n    }\n  }\n];"
                                     },
