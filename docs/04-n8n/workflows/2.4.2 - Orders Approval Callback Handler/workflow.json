                                                          }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const query = $json.callback_query;\n\nconst data = query.data || \"\";\nconst chat_id = query.message?.chat?.id || \"\";\nconst callback_query_id = query.id || \"\";\nconst clicked_by = query.from?.first_name || \"Unknown\";\n\nlet decision = \"\";\nlet order_id = \"\";\n\nif (data.startsWith(\"approve_\")) {\n  decision = \"approve\";\n  order_id = data.replace(\"approve_\", \"\").trim().toUpperCase();\n} else if (data.startsWith(\"reject_\")) {\n  decision = \"reject\";\n  order_id = data.replace(\"reject_\", \"\").trim().toUpperCase();\n}\n\nif (!decision || !order_id) {\n  return [\n    {\n      json: {\n        action: \"invalid_callback\",\n        reason: \"Malformed callback data\",\n        chat_id: String(chat_id),\n        callback_query_id,\n        changed_by: clicked_by,\n        trigger_source: \"Telegram Button\",\n        clicked_by,\n        decision_method: \"Button\"\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      action: \"process_order_approval_reply\",\n      decision,\n      order_id,\n      chat_id: String(chat_id),\n      callback_query_id,\n      changed_by: clicked_by,\n      trigger_source: \"Telegram Button\",\n      clicked_by,\n      decision_method: \"Button\"\n    }\n  }\n];"
                                     },
