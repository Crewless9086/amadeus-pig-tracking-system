        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "ac12f1b8-d4ce-4427-8aa8-5c46c429c9b3",
              "leftValue": "={{$json.selected_count}}",
              "rightValue": 0,
              "operator": {
