    {
      "parameters": {
        "jsCode": "const body = $json;\n\nconst MEDIA_CONFIG = {\n  newborns: { folder_id: \"1wSMHb1QiEiEvUkdfH7S8jyoh43_c7krI\", display: \"Newborn piglets\" },\n  weaners:   { folder_id: \"1FBLSZmd_h8VTGPIHYSFLx0UvgSMGQpsg\", display: \"Weaner piglets\" },\n  growers:   { folder_id: \"1S6HqMrLD9rnrzX6nnCWXt4On9sjseok2\", display: \"Grower pigs\" },\n  finishers: { folder_id: \"1zzW5I1iDflXyG2OUFUoiIcpWysJ8RNw3\", display: \"Finisher pigs\" },\n  slaughter: { folder_id: \"1aVzYeQlRJu0bbLcMhO2G3zAuNXQV94Wu\", display: \"Slaughter pigs\" }\n};\n\nconst category = (body.category_key || \"\").toLowerCase().trim();\nif (!MEDIA_CONFIG[category]) {\n  return [{\n    error: `Unknown category_key: ${category}`,\n    ok: false\n  }];\n}\n\nreturn [{\n  ok: true,\n  account_id: Number(body.account_id || 147387),\n  conversation_id: Number(body.conversation_id),\n  inbox_id: Number(body.inbox_id || 0),\n  category_key: category,\n  folder_id: MEDIA_CONFIG[category].folder_id,\n  category_display: MEDIA_CONFIG[category].display,\n  send_mode: (body.send_mode || \"latest\").toLowerCase(),\n  count: Number(body.count || 5)\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "88b01cb4-6ffd-4fcf-9b75-ca2af566f792",
      "name": "Resolve Config + Defaults"
    },
    {
      "parameters": {
        "url": "=https://app.chatwoot.com/api/v1/accounts/{{$json.account_id}}/conversations/{{$json.conversation_id}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api_access_token",
              "value": "F5tQGAj9v4KCrV7cio8SGhEe"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        416,
