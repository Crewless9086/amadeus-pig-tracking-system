      ],
      "id": "ea3281d5-32e7-4c5b-a4f5-dc774c26d3f7",
      "name": "Get Conversation"
    },
    {
      "parameters": {
        "jsCode": "const cfg = $items(\"Resolve Config + Defaults\")[0].json;\nconst convo = $json?.data || $json; // depending on node output shape\nconst attrs = convo?.custom_attributes || convo?.conversation?.custom_attributes || {};\n\nlet offsetMap = {};\ntry {\n  offsetMap = JSON.parse(attrs.images_sent_offset_map || \"{}\");\n} catch (e) {\n  offsetMap = {};\n}\n\nconst category = cfg.category_key;\nconst currentOffset = Number(offsetMap[category] || 0);\nconst sendMode = cfg.send_mode;\nconst count = cfg.count;\n\nconst offset = (sendMode === \"next\") ? currentOffset : 0;\n\nreturn [{\n  ...cfg,\n  current_offset: currentOffset,\n  offset,\n  offset_map: offsetMap\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "9e7e1828-7b5b-4109-8854-5d37304fdd2b",
      "name": "Read Offset + Decide Slice"
    },
    {
      "parameters": {
        "resource": "fileFolder",
        "searchMethod": "query",
        "queryString": "='{{ $json.folder_id }}' in parents and trashed=false and mimeType contains 'image/'",
        "returnAll": true,
        "filter": {},
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        832,
        0
      ],
      "id": "490fe09e-5613-40ed-8d45-2d01f7fe8dac",
      "name": "List Files",
      "alwaysOutputData": false,
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "VYmV2PgAl8l49sQ2",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const meta = $items(\"Read Offset + Decide Slice\")[0].json;\nconst files = $json?.files || $json; // depending on node output\n\n// Normalize array\nconst arr = Array.isArray(files) ? files : (files.files || []);\n\n// Filter images only\nconst images = arr.filter(f => (f.mimeType || \"\").startsWith(\"image/\"));\n\n// Sort newest first by createdTime (fallback modifiedTime)\nimages.sort((a, b) => {\n  const ta = new Date(a.createdTime || a.modifiedTime || 0).getTime();\n  const tb = new Date(b.createdTime || b.modifiedTime || 0).getTime();\n  return tb - ta;\n});\n\nconst offset = meta.offset;\nconst count = meta.count;\nconst selected = images.slice(offset, offset + count);\n\nreturn [{\n  ...meta,\n  total_images_in_folder: images.length,\n  selected_count: selected.length,\n  selected_files: selected.map(f => ({\n    id: f.id,\n    name: f.name,\n    mimeType: f.mimeType,\n    createdTime: f.createdTime,\n    webViewLink: f.webViewLink,\n  }))\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        0
      ],
      "id": "b1b0fb6d-c54b-434c-ba30-7ca5ab285cab",
      "name": "Sort + Select 5"
    },
