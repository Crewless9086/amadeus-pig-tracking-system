                                   ],
                      "id":  "0f86b7c2-37f8-4d2d-90bd-7bd57aef405f",
                      "name":  "Filter Next 3 Days"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Build Forecast Alert Candidates (GROUPED: Rain + Wind + Heat)\n// Outputs ONE alert per type (same pattern as Sunsynk / Station)\n\nconst data = $input.first().json || {};\nconst rows = data.forecast_rows_3day || [];\n\n// --- thresholds ---\nconst WIND_THRESHOLD_KMH = 40;\nconst TEMP_MAX_ALERT = 28;\nconst RAIN_MM_ALERT = 0.5;\nconst RAIN_PROB_ALERT = 60;\n\nconst COOLDOWN_MIN_DEFAULT = 120;\n\nfunction num(v) {\n  const n = Number(v);\n  return Number.isFinite(n) ? n : 0;\n}\n\nfunction zaNowISO() {\n  return new Date().toISOString();\n}\n\nfunction fmt1(v) {\n  const n = Number(v);\n  return Number.isFinite(n) ? n.toFixed(1) : String(v ?? \"\");\n}\n\nconst candidates = [];\n\n// =======================\n// 🌧️ RAIN (GROUPED)\n// =======================\nconst rainDays = [];\n\nfor (const r of rows) {\n  const date = r.forecast_date ?? r.date ?? r.Date;\n  if (!date) continue;\n\n  const rainMM = num(r.rain_sum_mm);\n  const rainProb = num(r.rain_prob_max_pct);\n\n  if (rainMM \u003e= RAIN_MM_ALERT || rainProb \u003e= RAIN_PROB_ALERT) {\n    rainDays.push({\n      date,\n      rainMM,\n      rainProb,\n      tmax: num(r.temp_max_c),\n      tmin: num(r.temp_min_c),\n      wind: num(r.wind_max_kmh),\n      gust: num(r.gust_max_kmh)\n    });\n  }\n}\n\nif (rainDays.length \u003e 0) {\n  const lines = rainDays.map(d =\u003e\n    `• *${d.date}:* ${fmt1(d.rainMM)} mm (${fmt1(d.rainProb)}%)`\n  ).join(\"\\n\");\n\n  candidates.push({\n    alert_key: \"FORECAST_RAIN_GROUP\",\n    alert_type: \"FORECAST_RAIN\",\n    severity: \"warning\",\n    cooldown_min: COOLDOWN_MIN_DEFAULT,\n    timestamp_alert_za: zaNowISO(),\n    days_affected: rainDays.length,\n    message:\n`🌧️ *WEATHER FORECAST ALERT — RAIN*\n${lines}\n\n🌡️ Temp range: _${fmt1(Math.min(...rainDays.map(d =\u003e d.tmin)))}°C → ${fmt1(Math.max(...rainDays.map(d =\u003e d.tmax)))}°C_\n🌬️ Wind up to _${fmt1(Math.max(...rainDays.map(d =\u003e d.gust)))} km/h_`\n  });\n}\n\n// =======================\n// 💨 WIND (GROUPED)\n// =======================\nconst windDays = [];\n\nfor (const r of rows) {\n  const date = r.forecast_date ?? r.date ?? r.Date;\n  if (!date) continue;\n\n  const wind = num(r.wind_max_kmh);\n\n  if (wind \u003e= WIND_THRESHOLD_KMH) {\n    windDays.push({\n      date,\n      wind,\n      gust: num(r.gust_max_kmh),\n      tmax: num(r.temp_max_c),\n      tmin: num(r.temp_min_c),\n      rainMM: num(r.rain_sum_mm)\n    });\n  }\n}\n\nif (windDays.length \u003e 0) {\n  const lines = windDays.map(d =\u003e\n    `• *${d.date}:* Wind ${fmt1(d.wind)} km/h (gust ${fmt1(d.gust)} km/h)`\n  ).join(\"\\n\");\n\n  candidates.push({\n    alert_key: \"FORECAST_WIND_GROUP\",\n    alert_type: \"FORECAST_WIND\",\n    severity: \"warning\",\n    cooldown_min: COOLDOWN_MIN_DEFAULT,\n    timestamp_alert_za: zaNowISO(),\n    days_affected: windDays.length,\n    message:\n`💨 *WEATHER FORECAST ALERT — WIND*\n${lines}\n\n🌡️ Temp range: _${fmt1(Math.min(...windDays.map(d =\u003e d.tmin)))}°C → ${fmt1(Math.max(...windDays.map(d =\u003e d.tmax)))}°C_\n🌧️ Rain up to _${fmt1(Math.max(...windDays.map(d =\u003e d.rainMM)))} mm_`\n  });\n}\n\n// =======================\n// 🔥 HEAT (GROUPED)\n// =======================\nconst heatDays = [];\n\nfor (const r of rows) {\n  const date = r.forecast_date ?? r.date ?? r.Date;\n  if (!date) continue;\n\n  const tmax = num(r.temp_max_c);\n\n  if (tmax \u003e TEMP_MAX_ALERT) {\n    heatDays.push({\n      date,\n      tmax,\n      tmin: num(r.temp_min_c),\n      wind: num(r.wind_max_kmh),\n      gust: num(r.gust_max_kmh),\n      rainMM: num(r.rain_sum_mm)\n    });\n  }\n}\n\nif (heatDays.length \u003e 0) {\n  const lines = heatDays.map(d =\u003e\n    `• *${d.date}:* Max ${fmt1(d.tmax)}°C (Min ${fmt1(d.tmin)}°C)`\n  ).join(\"\\n\");\n\n  candidates.push({\n    alert_key: \"FORECAST_HEAT_GROUP\",\n    alert_type: \"FORECAST_HEAT\",\n    severity: \"warning\",\n    cooldown_min: COOLDOWN_MIN_DEFAULT,\n    timestamp_alert_za: zaNowISO(),\n    days_affected: heatDays.length,\n    message:\n`🔥 *WEATHER FORECAST ALERT — HEAT*\n${lines}\n\n🌬️ Wind up to _${fmt1(Math.max(...heatDays.map(d =\u003e d.gust)))} km/h_\n🌧️ Rain expected: _${fmt1(Math.max(...heatDays.map(d =\u003e d.rainMM)))} mm_`\n  });\n}\n\n// =======================\n// OUTPUT\n// =======================\nreturn candidates.map(c =\u003e ({ json: c }));\n"
                                     },
