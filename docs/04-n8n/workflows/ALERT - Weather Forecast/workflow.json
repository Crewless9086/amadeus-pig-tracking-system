                      "parameters":  {
                                         "jsCode":  "function parseDateSafe(s) {\n  if (!s) return null;\n  const d = new Date(s);\n  return isNaN(d.getTime()) ? null : d;\n}\n\nconst all = $input.all().map(i =\u003e i.json);\n\n// ✅ Only treat rows with timestamp_alert_za as “candidates”\nconst candidates = all.filter(r =\u003e r.alert_key \u0026\u0026 r.timestamp_alert_za);\n\n// ✅ Only treat rows with last_timestamp_za as “log rows”\nconst logs = all.filter(r =\u003e r.alert_key \u0026\u0026 r.last_timestamp_za);\n\n// Build last sent map\nconst lastByKey = new Map();\nfor (const row of logs) {\n  const last = parseDateSafe(row.last_timestamp_za);\n  if (!last) continue;\n  const prev = lastByKey.get(row.alert_key);\n  if (!prev || last \u003e prev) lastByKey.set(row.alert_key, last);\n}\n\nconst now = new Date();\nconst allowed = [];\n\nfor (const c of candidates) {\n  const key = c.alert_key;\n  const cooldownMin = Number(c.cooldown_min ?? 0);\n\n  const last = lastByKey.get(key);\n\n  // Never sent before\n  if (!last) {\n    allowed.push(c);\n    continue;\n  }\n\n  // Special case: “send once” alerts\n  // If you truly want “only once ever”, keep it as 999999 and block forever:\n  // if (cooldownMin \u003e= 999999) continue;\n\n  const effectiveCooldown = cooldownMin \u003e= 999999 ? (24 * 60) : cooldownMin;\n\n  const diffMin = (now.getTime() - last.getTime()) / 60000;\n  if (diffMin \u003e= effectiveCooldown) allowed.push(c);\n}\n\nreturn allowed.map(a =\u003e ({ json: a }));\n"
                                     },
