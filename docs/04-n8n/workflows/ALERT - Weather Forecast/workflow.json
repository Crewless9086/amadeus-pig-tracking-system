                                         "jsCode":  "const chatIds = [\"5721652188\", \"8235612950\", \"8228742738\"];\n\nconst out = [];\nfor (const item of $input.all()) {\n  for (const chatId of chatIds) {\n    out.push({\n      json: {\n        chatId,\n        message: item.json.message,\n        alert_key: item.json.alert_key,\n        alert_type: item.json.alert_type,\n        severity: item.json.severity,\n        cooldown_min: item.json.cooldown_min,\n        timestamp_alert_za: item.json.timestamp_alert_za || item.json.timestamp_za,\n        // keep the full candidate object if you want\n        _candidate: item.json,\n      }\n    });\n  }\n}\nreturn out;\n"
