                  {
                      "parameters":  {
                                         "jsCode":  "// Filter Next 3 Days (ZA anchored)\n// Keeps only forecast rows for ZA \"today\" + next 2 days (total 3 days)\n\nfunction toDateStrZA(date = new Date()) {\n  // Build YYYY-MM-DD in Africa/Johannesburg without relying on server timezone\n  const parts = new Intl.DateTimeFormat(\"en-CA\", {\n    timeZone: \"Africa/Johannesburg\",\n    year: \"numeric\",\n    month: \"2-digit\",\n    day: \"2-digit\",\n  }).formatToParts(date);\n\n  const y = parts.find(p =\u003e p.type === \"year\")?.value;\n  const m = parts.find(p =\u003e p.type === \"month\")?.value;\n  const d = parts.find(p =\u003e p.type === \"day\")?.value;\n  return `${y}-${m}-${d}`;\n}\n\nfunction addDays(dateStr, days) {\n  // dateStr must be YYYY-MM-DD\n  const [y, m, d] = dateStr.split(\"-\").map(Number);\n  const dt = new Date(Date.UTC(y, m - 1, d));\n  dt.setUTCDate(dt.getUTCDate() + days);\n\n  const yy = dt.getUTCFullYear();\n  const mm = String(dt.getUTCMonth() + 1).padStart(2, \"0\");\n  const dd = String(dt.getUTCDate()).padStart(2, \"0\");\n  return `${yy}-${mm}-${dd}`;\n}\n\nconst all = $input.all().map(i =\u003e i.json);\n\n// ZA \"today\"\nconst todayZA = toDateStrZA(new Date());\nconst endZA = addDays(todayZA, 2); // today + 2 days = 3-day window\n\n// Keep rows where forecast_date is within [todayZA, endZA]\nconst filtered = all.filter(r =\u003e {\n  const fd = r.forecast_date ?? r.ForecastDate ?? r.date ?? r.Date;\n  if (!fd) return false;\n\n  // Ensure we only use YYYY-MM-DD part\n  const fdStr = String(fd).slice(0, 10);\n  return fdStr \u003e= todayZA \u0026\u0026 fdStr \u003c= endZA;\n});\n\n// Output in a single object (so your next node can read forecast_rows_3day)\nreturn [{\n  json: {\n    timezone: \"Africa/Johannesburg\",\n    anchor_today_za: todayZA,\n    window_end_za: endZA,\n    forecast_rows_3day: filtered\n  }\n}];\n"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       368,
