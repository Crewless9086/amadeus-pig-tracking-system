                  {
                      "parameters":  {
                                         "jsCode":  "// Get last row\nif (!items.length) {\n  return [{ json: { _error: \"No rows returned from Sunsynk_Log\" } }];\n}\nconst row = items[0].json;\n\n// Helpers\nconst asNum = (v) =\u003e {\n  if (v === null || v === undefined || v === \"\") return null;\n  const n = Number(v);\n  return Number.isFinite(n) ? n : null;\n};\nconst asBool = (v) =\u003e {\n  if (typeof v === \"boolean\") return v;\n  if (v === null || v === undefined) return null;\n  const s = String(v).toLowerCase().trim();\n  if ([\"true\", \"1\", \"yes\", \"y\"].includes(s)) return true;\n  if ([\"false\", \"0\", \"no\", \"n\"].includes(s)) return false;\n  return null;\n};\n\n// Normalize the important fields\nrow.battery_soc = asNum(row.battery_soc);\nrow.battery_power_w = asNum(row.battery_power_w);\nrow.pv_power_w = asNum(row.pv_power_w);\nrow.pv1_power_w = asNum(row.pv1_power_w);\nrow.pv2_power_w = asNum(row.pv2_power_w);\nrow.load_power_w = asNum(row.load_power_w);\nrow.grid_power_w = asNum(row.grid_power_w);\nrow.gen_power_w = asNum(row.gen_power_w);\nrow.inv_pinv_w = asNum(row.inv_pinv_w);\nrow.inv_pac_w = asNum(row.inv_pac_w);\n\nrow.grid_active = asBool(row.grid_active);\nrow.gen_active = asBool(row.gen_active);\nrow.battery_charging = asBool(row.battery_charging);\nrow.battery_discharging = asBool(row.battery_discharging);\n\n// Compute now in Africa/Johannesburg\nfunction nowZA() {\n  const s = new Intl.DateTimeFormat(\"en-CA\", {\n    timeZone: \"Africa/Johannesburg\",\n    year: \"numeric\", month: \"2-digit\", day: \"2-digit\",\n    hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\",\n    hour12: false\n  }).format(new Date());\n  return new Date(s.replace(\", \", \"T\") + \"+02:00\");\n}\nconst now = nowZA();\n\n// Parse last timestamp from sheet (timestamp_za OR date_za+time_za)\nfunction parseZA(ts, d, t) {\n  if (ts \u0026\u0026 String(ts).trim()) {\n    const s = String(ts).trim();\n    const iso = (s.includes(\"+\") || s.endsWith(\"Z\")) ? s : s.replace(\" \", \"T\") + \"+02:00\";\n    const dt = new Date(iso);\n    return isNaN(dt) ? null : dt;\n  }\n  if (d \u0026\u0026 t) {\n    const dt = new Date(`${d}T${t}+02:00`);\n    return isNaN(dt) ? null : dt;\n  }\n  return null;\n}\n\nconst lastTs = parseZA(row.timestamp_za, row.date_za, row.time_za);\nconst diffMinutes = lastTs ? (now - lastTs) / 60000 : Number.POSITIVE_INFINITY;\n\nconst fmtZA = (d) =\u003e new Intl.DateTimeFormat(\"sv-SE\", {\n  timeZone: \"Africa/Johannesburg\",\n  year: \"numeric\", month: \"2-digit\", day: \"2-digit\",\n  hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\",\n  hour12: false\n}).format(d).replace(\" \", \"T\") + \"+02:00\";\n\nrow._now_za = fmtZA(new Date());\nrow._last_ts = lastTs ? fmtZA(lastTs) : null;\n;\nrow._diff_minutes = diffMinutes;\n\nreturn [{ json: row }];\n"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       368,
