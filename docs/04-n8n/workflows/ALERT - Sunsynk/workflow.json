                      "id":  "025407d3-bcdd-4fd1-93f0-0fa7ea4ca3c5",
                      "name":  "Latest Row + Normalize"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const row = items[0].json;\n\n// --------------------\n// Thresholds\n// --------------------\nconst NOT_LOGGING_MIN = 12;\nconst GRID_W_THRESHOLD = 100;\nconst GEN_W_THRESHOLD = 100; // \"actually giving power\" threshold\n\n// --------------------\n// Cooldowns (minutes)\n// --------------------\nconst cooldown = {\n  not_logging: 240,\n  batt_low_30: 180,\n  batt_med_50: 360,\n  batt_high_95: 180,\n  grid_active: 180,\n  gen_active: 180, // ✅ new\n};\n\n// --------------------\n// Helper: safe numbers\n// --------------------\nconst num = (v) =\u003e {\n  const n = Number(v);\n  return Number.isFinite(n) ? n : 0;\n};\n\n// --------------------\n// Grid rule C (Both)\n// --------------------\nconst grid_power = num(row.grid_power_w);\nconst gridRuleC = (row.grid_active === true) || (grid_power \u003e GRID_W_THRESHOLD);\n\n// --------------------\n// Generator rule:\n// \"gen is being used AND actually giving power\"\n// --------------------\nconst gen_power = num(row.gen_power_w);\nconst genRule = ((row.gen_active === true) || (gen_power \u003e 0)) \u0026\u0026 (gen_power \u003e GEN_W_THRESHOLD);\n\n// --------------------\n// Alert conditions\n// --------------------\nconst alerts = [];\n\n// 1) Not logging\nif (num(row._diff_minutes) \u003e NOT_LOGGING_MIN) {\n  alerts.push({\n    alert_key: \"not_logging\",\n    alert_type: \"NOT_LOGGING\",\n    severity: \"HIGH\",\n    cooldown_min: cooldown.not_logging,\n    message: `⚠️ *Sunsynk Alert*: Not logging\\nLast data is *${Math.round(num(row._diff_minutes))} min* old.\\nLast timestamp: ${row.timestamp_za || row._last_ts || \"unknown\"}`\n  });\n}\n\n// 2) Battery low 30\nif (row.battery_soc !== null \u0026\u0026 row.battery_soc !== \"\" \u0026\u0026 num(row.battery_soc) \u003c= 30) {\n  alerts.push({\n    alert_key: \"batt_low_30\",\n    alert_type: \"BATTERY_LOW_30\",\n    severity: \"HIGH\",\n    cooldown_min: cooldown.batt_low_30,\n    message: `🔴 *Sunsynk Alert*: Battery LOW (≤30%)\\nSOC: *${num(row.battery_soc)}%*`\n  });\n}\n\n// 3) Battery med 50\nif (row.battery_soc !== null \u0026\u0026 row.battery_soc !== \"\" \u0026\u0026 num(row.battery_soc) \u003c= 50) {\n  alerts.push({\n    alert_key: \"batt_med_50\",\n    alert_type: \"BATTERY_MED_50\",\n    severity: \"MED\",\n    cooldown_min: cooldown.batt_med_50,\n    message: `🟠 *Sunsynk Alert*: Battery MED (≤50%)\\nSOC: *${num(row.battery_soc)}%*`\n  });\n}\n\n// 4) Battery high 95\nif (row.battery_soc !== null \u0026\u0026 row.battery_soc !== \"\" \u0026\u0026 num(row.battery_soc) \u003e= 95) {\n  alerts.push({\n    alert_key: \"batt_high_95\",\n    alert_type: \"BATTERY_HIGH_95\",\n    severity: \"INFO\",\n    cooldown_min: cooldown.batt_high_95,\n    message: `🟢 *Sunsynk Alert*\\nBattery is HIGH, greater than (95%)\\nSOC: *${num(row.battery_soc)}%*`\n  });\n}\n\n// 5) Grid active\nif (gridRuleC) {\n  alerts.push({\n    alert_key: \"grid_active\",\n    alert_type: \"GRID_ACTIVE\",\n    severity: \"MED\",\n    cooldown_min: cooldown.grid_active,\n    message: `⚡ *Sunsynk Alert*: Grid \"Eskom\" is being used\\nGrid power: *${grid_power} W*\\n(grid_active: ${row.grid_active})`\n  });\n}\n\n// 6) ✅ Generator active (actually producing power)\nif (genRule) {\n  alerts.push({\n    alert_key: \"gen_active\",\n    alert_type: \"GEN_ACTIVE\",\n    severity: \"HIGH\",\n    cooldown_min: cooldown.gen_active,\n    message: `🛢️ *Sunsynk Alert*: Generator is supplying power\\nGen power: *${gen_power} W*\\n(gen_active: ${row.gen_active})`\n  });\n}\n\n// --------------------\n// Return items\n// --------------------\nreturn alerts.map(a =\u003e ({\n  json: {\n    ...row,\n    ...a,\n    timestamp_alert_za: row.timestamp_za || row._last_ts || row._now_za,\n  }\n}));\n"
                                     },
