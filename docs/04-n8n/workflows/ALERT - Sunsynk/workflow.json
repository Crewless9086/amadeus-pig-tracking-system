                                         "jsCode":  "const items = $input.all();\nif (!items.length) return [];\n\nconst nowZa = new Date().toLocaleString(\"en-ZA\", { timeZone: \"Africa/Johannesburg\" });\n// nowZa looks like \"2025/12/27, 10:15:00\"\nconst hh = Number(nowZa.split(\",\")[1].trim().split(\":\")[0]);\n\n// Quiet hours: 22:00–06:00 (no alerts)\nconst isQuiet = (hh \u003e= 22 || hh \u003c 6);\nif (isQuiet) return [];\n\nreturn items;\n"
