                      "name":  "Get Forecast (Open-Meteo)"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// ---- Inputs (preferred) ----\n// offsetDays: 0..10 (single day)\n// startOffsetDays/endOffsetDays: 0..10 (range)\n\n// Backwards compatible \"day\" string:\n// \"today\" =\u003e 0\n// \"tomorrow\" =\u003e 1\n\nconst setNode = $node[\"Set Forecast Inputs\"]?.json || {};\nconst data = $json;\n\nconst daily = data.daily;\nif (!daily || !daily.time || daily.time.length === 0) {\n  return [{ json: { ok: false, source: \"Open-Meteo\", reason: \"No daily forecast data returned.\" } }];\n}\n\n// ---------- helper ----------\nfunction clampInt(n, min, max) {\n  const x = Number.parseInt(n, 10);\n  if (Number.isNaN(x)) return null;\n  return Math.max(min, Math.min(max, x));\n}\n\nlet startOffset = null;\nlet endOffset = null;\nlet offset = null;\n\n// Only treat as \"range\" if startOffsetDays/endOffsetDays are actually provided (not blank/null)\nconst hasStart = setNode.startOffsetDays !== undefined \u0026\u0026 setNode.startOffsetDays !== null \u0026\u0026 setNode.startOffsetDays !== \"\";\nconst hasEnd   = setNode.endOffsetDays   !== undefined \u0026\u0026 setNode.endOffsetDays   !== null \u0026\u0026 setNode.endOffsetDays   !== \"\";\n\nif (hasStart || hasEnd) {\n  startOffset = clampInt(hasStart ? setNode.startOffsetDays : 0, 0, 10);\n  endOffset   = clampInt(hasEnd ? setNode.endOffsetDays : startOffset, 0, 10);\n\n  if (startOffset === null || endOffset === null) {\n    return [{ json: { ok: false, source: \"Open-Meteo\", reason: \"Invalid startOffsetDays/endOffsetDays.\" } }];\n  }\n  if (endOffset \u003c startOffset) [startOffset, endOffset] = [endOffset, startOffset];\n}\n// Else prefer explicit single offset\nelse if (setNode.offsetDays !== undefined \u0026\u0026 setNode.offsetDays !== null \u0026\u0026 setNode.offsetDays !== \"\") {\n  offset = clampInt(setNode.offsetDays, 0, 10);\n  if (offset === null) {\n    return [{ json: { ok: false, source: \"Open-Meteo\", reason: \"Invalid offsetDays.\" } }];\n  }\n}\n// Else fall back to \"day\" string\nelse {\n  const dayStr = (setNode.day || \"today\").toLowerCase().trim();\n  if (dayStr === \"today\") offset = 0;\n  else if (dayStr === \"tomorrow\") offset = 1;\n  else {\n    return [{\n      json: {\n        ok: false,\n        source: \"Open-Meteo\",\n        reason: `Unsupported \u0027day\u0027 value: \u0027${setNode.day}\u0027. Use offsetDays or startOffsetDays/endOffsetDays.`\n      }\n    }];\n  }\n}\n\n\n// Build output\nconst tz = data.timezone || \"Africa/Johannesburg\";\n\nfunction buildRow(idx) {\n  if (idx \u003c 0 || idx \u003e= daily.time.length) return null;\n  return {\n    date: daily.time[idx],\n    temp_max_c: daily.temperature_2m_max?.[idx],\n    temp_min_c: daily.temperature_2m_min?.[idx],\n    rain_sum_mm: daily.precipitation_sum?.[idx],\n    wind_max_kmh: daily.wind_speed_10m_max?.[idx],\n    gust_max_kmh: daily.wind_gusts_10m_max?.[idx],\n  };\n}\n\n// Range mode\nif (startOffset !== null \u0026\u0026 endOffset !== null) {\n  const rows = [];\n  for (let i = startOffset; i \u003c= endOffset; i++) {\n    const r = buildRow(i);\n    if (r) rows.push({ ...r, offsetDays: i });\n  }\n\n  if (rows.length === 0) {\n    return [{ json: { ok: false, source: \"Open-Meteo\", reason: \"Requested range not available in forecast.\" } }];\n  }\n\n  return [{\n    json: {\n      ok: true,\n      source: \"Open-Meteo\",\n      timezone: tz,\n      mode: \"range\",\n      startOffsetDays: startOffset,\n      endOffsetDays: endOffset,\n      days: rows\n    }\n  }];\n}\n\n// Single-day mode\nconst single = buildRow(offset);\nif (!single) {\n  return [{ json: { ok: false, source: \"Open-Meteo\", reason: \"Requested offset not available in forecast.\" } }];\n}\n\nreturn [{\n  json: {\n    ok: true,\n    source: \"Open-Meteo\",\n    timezone: tz,\n    mode: \"single\",\n    offsetDays: offset,\n    day_requested: offset === 0 ? \"today\" : offset === 1 ? \"tomorrow\" : `in ${offset} days`,\n    ...single\n  }\n}];\n"
                                     },
