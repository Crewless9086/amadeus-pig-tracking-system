                  {
                      "parameters":  {
                                         "jsCode":  "// INPUTS:\n// 1) Item 0 = LLM_Latest_Reading row (from node \"Get LLM_Latest_Reading (Weather)\")\n// 2) All items may include today\u0027s readings from \"Get LLM_Today_Readings (Weather)\" if merged later.\n// We\u0027ll keep this node only for latest row normalization. Today rows get handled in the next node.\n\nif (!items.length) {\n  return [{ json: { _error: \"No rows returned from LLM_Latest_Reading\" } }];\n}\n\nconst row = items[0].json;\n\n// ---------- helpers ----------\nconst num = (v) =\u003e {\n  if (v === null || v === undefined || v === \"\") return null;\n  const n = Number(v);\n  return Number.isFinite(n) ? n : null;\n};\n\nfunction nowZA() {\n  const s = new Intl.DateTimeFormat(\"en-CA\", {\n    timeZone: \"Africa/Johannesburg\",\n    year: \"numeric\", month: \"2-digit\", day: \"2-digit\",\n    hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\",\n    hour12: false\n  }).format(new Date());\n  // \"YYYY-MM-DD, HH:MM:SS\"\n  return new Date(s.replace(\", \", \"T\") + \"+02:00\");\n}\n\n// Parse \"YYYY-MM-DD HH:MM:SS\" (your logging format)\nfunction parseZA(ts) {\n  if (!ts) return null;\n  const s = String(ts).trim();\n  // if sheet already returns a Date object, keep it\n  if (ts instanceof Date \u0026\u0026 !isNaN(ts.getTime())) return ts;\n  const iso = s.includes(\"T\") ? s : s.replace(\" \", \"T\");\n  const dt = new Date(iso + \"+02:00\");\n  return isNaN(dt.getTime()) ? null : dt;\n}\n\nfunction fmtZA(dt) {\n  // Output same style every time: YYYY-MM-DD HH:MM:SS\n  const s = new Intl.DateTimeFormat(\"sv-SE\", {\n    timeZone: \"Africa/Johannesburg\",\n    year: \"numeric\", month: \"2-digit\", day: \"2-digit\",\n    hour: \"2-digit\", minute: \"2-digit\", second: \"2-digit\",\n    hour12: false\n  }).format(dt);\n  return s; // \"YYYY-MM-DD HH:MM:SS\"\n}\n\n// ---------- normalize fields ----------\nrow.Timestamp = row.Timestamp ?? row.timestamp ?? row[\"Timestamp\"] ?? row[\"timestamp\"] ?? null;\n\nrow.Temperature = num(row.Temperature);\nrow[\"Wind Speed\"] = num(row[\"Wind Speed\"]);\nrow[\"Wind Gust\"] = num(row[\"Wind Gust\"]);\nrow[\"Wind Direction\"] = num(row[\"Wind Direction\"]);\nrow[\"Rain Rate\"] = num(row[\"Rain Rate\"]);\nrow[\"Total Rain\"] = num(row[\"Total Rain\"]);\nrow.Pressure = num(row.Pressure);\nrow.Humidity = num(row.Humidity);\n\n// ---------- compute age ----------\nconst now = nowZA();\nconst lastTs = parseZA(row.Timestamp);\n\nconst diffMinutes = lastTs ? (now - lastTs) / 60000 : Number.POSITIVE_INFINITY;\n\nrow._now_za = fmtZA(now);\nrow._last_ts_za = lastTs ? fmtZA(lastTs) : null;\nrow._diff_minutes = diffMinutes;\n\nreturn [{ json: row }];\n"
                                     },
