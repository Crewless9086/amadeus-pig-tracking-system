                      "id":  "e225e577-f470-4c8a-a63d-5b6abad32997",
                      "name":  "Merge Latest + Today"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const all = $input.all().map(i =\u003e i.json);\n\n// Split latest row vs today rows\n// Latest row will have _diff_minutes because Normalize node added it.\nconst latest = all.find(r =\u003e r._diff_minutes !== undefined) || {};\nconst todayRows = all.filter(r =\u003e r.Timestamp \u0026\u0026 r._diff_minutes === undefined);\n\n// --------------------\n// Thresholds \u0026 Settings\n// --------------------\nconst STALE_THRESHOLD_MIN = 12;\n\n// Cooldowns (minutes)\nconst COOLDOWN_DEFAULT = 120;\nconst COOLDOWN_RAIN_RATE = 60;\nconst COOLDOWN_STALE = 240; // keep this longer so it doesn\u0027t spam if station is down\n\n// Weather thresholds\nconst TEMP_HIGH = 28;\nconst TEMP_LOW = 10;\nconst WIND_SPEED_HIGH = 40;       // sustained rule uses todayRows\nconst WIND_GUST_HIGH = 60;\nconst RAIN_RATE_ANY = 0;          // \u003e 0 triggers\nconst TOTAL_RAIN_HIGH = 2;\nconst HUMIDITY_HIGH = 85;\n\n// --------------------\n// Helpers\n// --------------------\nconst num = (v) =\u003e {\n  const n = Number(v);\n  return Number.isFinite(n) ? n : null;\n};\n\nfunction parseZA(ts) {\n  if (!ts) return null;\n  if (ts instanceof Date \u0026\u0026 !isNaN(ts.getTime())) return ts;\n  const s = String(ts).trim();\n  const iso = s.includes(\"T\") ? s : s.replace(\" \", \"T\");\n  const dt = new Date(iso + \"+02:00\");\n  return isNaN(dt.getTime()) ? null : dt;\n}\n\n// sustained wind: \"more than 10 min or two loggings\"\n// Your logging is every 5 min, so two consecutive rows is enough.\n// We\u0027ll check the last 3 rows to be safe.\nfunction sustainedWindOver40(rows) {\n  if (!rows || rows.length \u003c 2) return false;\n\n  // sort by timestamp\n  const sorted = rows\n    .map(r =\u003e ({ ...r, _ts: parseZA(r.Timestamp), _ws: num(r[\"Wind Speed\"] ?? r.WindSpeed ?? r.wind_speed) }))\n    .filter(r =\u003e r._ts \u0026\u0026 r._ws !== null)\n    .sort((a,b) =\u003e a._ts - b._ts);\n\n  if (sorted.length \u003c 2) return false;\n\n  const last = sorted[sorted.length - 1];\n  const prev = sorted[sorted.length - 2];\n\n  // ensure close in time (\u003c= 12 minutes to allow small drift)\n  const diffMin = (last._ts - prev._ts) / 60000;\n\n  return diffMin \u003c= 12 \u0026\u0026 last._ws \u003e WIND_SPEED_HIGH \u0026\u0026 prev._ws \u003e WIND_SPEED_HIGH;\n}\n\n// --------------------\n// Build alerts\n// --------------------\nconst alerts = [];\n\nconst stamp = latest.Timestamp || latest._last_ts_za || latest._now_za || null;\n\n// 1) Station stale/offline\nif (num(latest._diff_minutes) !== null \u0026\u0026 num(latest._diff_minutes) \u003e STALE_THRESHOLD_MIN) {\n  alerts.push({\n    alert_key: \"station_stale\",\n    alert_type: \"STATION_STALE\",\n    severity: \"HIGH\",\n    cooldown_min: COOLDOWN_STALE,\n    message: `⚠️ *Weather Station Alert*: Not logging\\nLast data is *${Math.round(num(latest._diff_minutes))} min* old.\\nLast timestamp: *${latest._last_ts_za || latest.Timestamp || \"unknown\"}*`,\n  });\n}\n\n// Only evaluate “current condition” thresholds if we have values\nconst t = num(latest.Temperature);\nconst ws = num(latest[\"Wind Speed\"]);\nconst wg = num(latest[\"Wind Gust\"]);\nconst rr = num(latest[\"Rain Rate\"]);\nconst tr = num(latest[\"Total Rain\"]);\nconst hum = num(latest.Humidity);\n\n// 2) Temp \u003e 28\nif (t !== null \u0026\u0026 t \u003e TEMP_HIGH) {\n  alerts.push({\n    alert_key: \"temp_high\",\n    alert_type: \"TEMP_HIGH\",\n    severity: \"MED\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `🌡️ *Current Weather Alert*: High temperature\\nTemp: *${t}°C* (\u003e${TEMP_HIGH}°C)\\nTime: *${stamp}*`,\n  });\n}\n\n// 3) Temp \u003c 10\nif (t !== null \u0026\u0026 t \u003c TEMP_LOW) {\n  alerts.push({\n    alert_key: \"temp_low\",\n    alert_type: \"TEMP_LOW\",\n    severity: \"HIGH\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `🥶 *Current Weather Alert*: Low temperature\\nTemp: *${t}°C* (\u003c${TEMP_LOW}°C)\\nTime: *${stamp}*`,\n  });\n}\n\n// 4) Wind speed \u003e 40 sustained (two loggings)\nif (sustainedWindOver40(todayRows)) {\n  alerts.push({\n    alert_key: \"wind_speed_sustained_40\",\n    alert_type: \"WIND_SPEED_SUSTAINED\",\n    severity: \"HIGH\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `💨 *Current Weather Alert*: Sustained high wind\\nWind Speed: *\u003e${WIND_SPEED_HIGH} km/h* for 2 loggings (~10 min)\\nTime: *${stamp}*`,\n  });\n}\n\n// 5) Wind gust \u003e 60\nif (wg !== null \u0026\u0026 wg \u003e WIND_GUST_HIGH) {\n  alerts.push({\n    alert_key: \"wind_gust_60\",\n    alert_type: \"WIND_GUST_HIGH\",\n    severity: \"HIGH\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `🌬️ *Current Weather Alert*: Strong gusts\\nGust: *${wg} km/h* (\u003e${WIND_GUST_HIGH} km/h)\\nTime: *${stamp}*`,\n  });\n}\n\n// 6) Rain rate \u003e 0 (it’s raining)\nif (rr !== null \u0026\u0026 rr \u003e RAIN_RATE_ANY) {\n  alerts.push({\n    alert_key: \"rain_rate\",\n    alert_type: \"RAINING_NOW\",\n    severity: \"MED\",\n    cooldown_min: COOLDOWN_RAIN_RATE,\n    message: `🌧️ *Current Weather Alert*: It’s raining\\nRain Rate: *${rr} mm/h*\\nTime: *${stamp}*`,\n  });\n}\n\n// 7) Total rain \u003e 2mm\nif (tr !== null \u0026\u0026 tr \u003e TOTAL_RAIN_HIGH) {\n  alerts.push({\n    alert_key: \"total_rain_2mm\",\n    alert_type: \"TOTAL_RAIN_HIGH\",\n    severity: \"INFO\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `🌧️ *Current Weather Alert*: Rain accumulation\\nTotal Rain: *${tr} mm* (\u003e${TOTAL_RAIN_HIGH} mm)\\nTime: *${stamp}*`,\n  });\n}\n\n// 8) Humidity \u003e 85%\nif (hum !== null \u0026\u0026 hum \u003e HUMIDITY_HIGH) {\n  alerts.push({\n    alert_key: \"humidity_high\",\n    alert_type: \"HUMIDITY_HIGH\",\n    severity: \"INFO\",\n    cooldown_min: COOLDOWN_DEFAULT,\n    message: `💧 *Current Weather Alert*: High humidity\\nHumidity: *${hum}%* (\u003e${HUMIDITY_HIGH}%)\\nTime: *${stamp}*`,\n  });\n}\n\n// Return as individual items (same as Sunsynk workflow)\nreturn alerts.map(a =\u003e ({\n  json: {\n    ...latest,\n    ...a,\n    timestamp_alert_za: latest._last_ts_za || latest.Timestamp || latest._now_za,\n  }\n}));\n"
                                     },
